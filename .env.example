ANTHROPIC_API_KEY=

# 테스트/CI에서는 0으로 설정하면 LLM 호출 없이 fallback으로 동작합니다.
MAFIA_USE_LLM=1

HOST=0.0.0.0
PORT=8000

CHROMA_PERSIST_DIR=./backend/rag/chroma_db
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
RAG_KNOWLEDGE_DIR=./docs/rag_knowledge

REDIS_URL=redis://localhost:6379
MAFIA_USE_REDIS_CHECKPOINTER=0

# GameInsightAgent 배치(analyze_pending): 한 번에 처리할 최대 게임 수 (비우면 제한 없음)
# MAFIA_INSIGHT_PENDING_LIMIT=10

MAX_PLAYERS=20
DAY_CHAT_SECONDS=180
DAY_VOTE_SECONDS=60
NIGHT_MAFIA_SECONDS=90
NIGHT_ABILITY_SECONDS=60
